# --- Supabase ---
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only. Bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres URL for Drizzle migrations.
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Get this from Supabase: Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- App ---
# Used for redirect URLs in auth flows. Set to your production URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
